#!/usr/bin/env bash

yma_dir=/jfs-dialogue-mmos02-rs02/yema

# alias vim="nvim --appimage-extract-and-run"
alias vim="nvim"
# alias nvim="nvim --appimage-extract-and-run"

alias sc='micromamba activate'
alias sd='micromamba deactivate'

export EDITOR="nvim"
export VISUAL="nvim"
export GIT_EDITOR="nvim"

# >>> mamba initialize >>>
# !! Contents within this block are managed by 'micromamba shell init' !!
export MAMBA_EXE='/jfs-dialogue-mmos02-rs02/yema/.local/bin/micromamba';
export MAMBA_ROOT_PREFIX='/jfs-dialogue-mmos02-rs02/yema/.local/share/mamba';
__mamba_setup="$("$MAMBA_EXE" shell hook --shell bash --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__mamba_setup"
else
    alias micromamba="$MAMBA_EXE"  # Fallback on help from micromamba activate
fi
unset __mamba_setup
# <<< mamba initialize <<<
alias mm=micromamba



alias qq="source $yma_dir/.bashrc"
alias vv="vim $yma_dir/.bashrc"
alias vb="vim $yma_dir/.bashrc_local_before"
alias va="vim $yma_dir/.bashrc_local_after"
