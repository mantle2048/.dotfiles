FROM nvcr.io/nvidia/pytorch:26.01-py3

ARG TZ=Asia/Shanghai
ARG MAX_JOBS=16
ARG PIP_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
ARG PIP_TRUSTED_HOST=
ARG APT_MIRROR=
ARG APT_CODENAME=
ARG SSH_PUBKEYS=

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=${TZ} \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_INDEX_URL=${PIP_INDEX_URL} \
    PIP_TRUSTED_HOST=${PIP_TRUSTED_HOST} \
    TORCH_CUDA_ARCH_LIST="8.6 9.0 10.0+PTX"

RUN if [ -n "${APT_MIRROR}" ]; then \
      . /etc/os-release; \
      CODENAME="${APT_CODENAME:-${VERSION_CODENAME:-${UBUNTU_CODENAME:-jammy}}}"; \
      printf '%s\n' \
        "deb ${APT_MIRROR} ${CODENAME} main restricted universe multiverse" \
        "deb ${APT_MIRROR} ${CODENAME}-updates main restricted universe multiverse" \
        "deb ${APT_MIRROR} ${CODENAME}-backports main restricted universe multiverse" \
        "deb ${APT_MIRROR} ${CODENAME}-security main restricted universe multiverse" \
        > /etc/apt/sources.list; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
    tzdata ca-certificates curl wget unzip \
    software-properties-common netcat-openbsd kmod openssh-server \
    iputils-tracepath traceroute net-tools iproute2 dnsutils \
    nano lsof zsh ccache tmux htop git-lfs bwm-ng tree rsync rclone iputils-ping \
    build-essential cmake patchelf \
    libopenmpi-dev libnuma1 libnuma-dev \
    libibverbs-dev libibverbs1 libibumad3 \
    librdmacm1 libnl-3-200 libnl-route-3-200 libnl-route-3-dev libnl-3-dev \
    ibverbs-providers infiniband-diags perftest libfabric-dev \
    && ln -snf /usr/share/zoneinfo/${TZ} /etc/localtime \
    && echo ${TZ} > /etc/timezone \
    && rm -rf /var/lib/apt/lists/*

# Non-interactive oh-my-zsh installation to avoid build hang.
RUN RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" --unattended \
    && echo "exec zsh" >> /root/.bashrc

RUN mkdir -p /root/.ssh && touch /root/.ssh/authorized_keys && \
    chmod 700 /root/.ssh && chmod 600 /root/.ssh/authorized_keys && \
    if [ -n "${SSH_PUBKEYS}" ]; then \
      printf '%s\n' "${SSH_PUBKEYS}" | while IFS= read -r key; do \
        [ -z "${key}" ] && continue; \
        grep -qxF "${key}" /root/.ssh/authorized_keys || echo "${key}" >> /root/.ssh/authorized_keys; \
      done; \
    fi

RUN python3 -m pip install --upgrade pip setuptools wheel && \
    pip config set global.index-url "${PIP_INDEX_URL}" && \
    if [ -n "${PIP_TRUSTED_HOST}" ]; then pip config set global.trusted-host "${PIP_TRUSTED_HOST}"; fi && \
    pip install -U \
      hydra-core==1.4.0.dev1 \
      git+https://github.com/acherstyx/hydra-torchrun-launcher.git \
      datasets tiktoken sentencepiece boto3 einops packaging nvitop oss2 wandb \
      pydantic jupyterlab isort TexSoup math-verify ninja psutil poetry colorlog \
      qwen-vl-utils ipdb ipython pytest yapf py-spy liger-kernel torchdata \
      torch-memory-saver codetiming ruff dill peft opencv-python fastapi \
      hf-transfer nvtx timm 'nvidia-ml-py>=12.560.30' 'optree>=0.13.0' \
      'pyarrow>=15.0.0' pybind11 pylatexenc tensordict 'ray[all]' sglang && \
    MAX_JOBS=${MAX_JOBS} pip install --no-build-isolation -U flash-attn
